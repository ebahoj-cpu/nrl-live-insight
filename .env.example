# ---------------------------------------------------------------------------
# LINEBREAK NRL — Environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# Supabase (Lovable Cloud) — find these in your Supabase / Lovable Cloud project
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_anon_key_here

# Vite-exposed mirrors (must match the values above; bundled into the client)
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_supabase_project_ref_here

# Server-only — NEVER expose to the client. Used by server functions / admin client.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional third-party APIs used by server functions (set only if you use them)
# ODDS_API_KEY=your_odds_api_key_here
# LOVABLE_API_KEY=managed_by_lovable
